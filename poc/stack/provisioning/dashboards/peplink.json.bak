            "lastNotNull"
          ]
        }
      }
    },
    {
      "id": 100,
      "type": "row",
      "title": "3. WAN Multi-Link Status (Enterprise SNMP)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 29
      },
      "collapsed": false
    },
    {
      "id": 101,
      "type": "table",
      "title": "WAN Interface Status \u2014 Balance 20X",
      "description": "Realtime WAN-status via Peplink enterprise SNMP OIDs. Status: 1=disabled, 2=disconnected, 3=connected. Link: 1=up, 0=down.",
      "gridPos": {
        "h": 7,
        "w": 16,
        "x": 0,
        "y": 30
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "peplink_snmp_wan_status{device_name=\"Balance20X\"}",
          "legendFormat": "Status",
          "refId": "A",
          "format": "table",
          "instant": true
        },
        {
          "expr": "peplink_snmp_wan_link_up{device_name=\"Balance20X\"}",
          "legendFormat": "Link",
          "refId": "B",
          "format": "table",
          "instant": true
        },
        {
          "expr": "peplink_snmp_wan_signal_dbm{device_name=\"Balance20X\"}",
          "legendFormat": "Signaal",
          "refId": "C",
          "format": "table",
          "instant": true
        },
        {
          "expr": "peplink_snmp_wan_healthcheck{device_name=\"Balance20X\"}",
          "legendFormat": "Health Check",
          "refId": "D",
          "format": "table",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #A"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Status"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "1": {
                        "text": "Disabled",
                        "color": "text"
                      },
                      "2": {
                        "text": "Disconnected",
                        "color": "orange"
                      },
                      "3": {
                        "text": "Connected",
                        "color": "green"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Link"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "0": {
                        "text": "Down",
                        "color": "red"
                      },
                      "1": {
                        "text": "Up",
                        "color": "green"
                      }
                    }
                  }
                ]
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Signaal (dBm)"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #D"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Health Check"
              },
              {
                "id": "mappings",
                "value": [
                  {
                    "type": "value",
                    "options": {
                      "-1": {
                        "text": "N/A"
                      }
                    }
                  }
                ]
              }
            ]
          }
        ]
      },
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "device_name": true,
              "ip": true,
              "__name__": true
            },
            "renameByName": {
              "wan_name": "WAN Interface"
            }
          }
        }
      ]
    },
    {
      "id": 102,
      "type": "stat",
      "title": "WAN Connected",
      "description": "Aantal WAN interfaces met status 'connected' (3)",
      "gridPos": {
        "h": 3,
        "w": 8,
        "x": 16,
        "y": 30
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "count(peplink_snmp_wan_status{device_name=\"Balance20X\"} == 3)",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        }
      }
    },
