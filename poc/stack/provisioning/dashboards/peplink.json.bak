{
  "title": "Mediaventures \u2014 Observability Dashboard",
  "uid": "peplink-infra",
  "tags": [
    "peplink",
    "incontrol2",
    "mediaventures"
  ],
  "refresh": "15s",
  "time": {
    "from": "now-1h",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "type": "text",
      "title": "",
      "gridPos": {
        "h": 2,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "options": {
        "content": "# Mediaventures \u2014 Live Streaming Infrastructuur\nCentraliseerde monitoring van netwerk, VPN-tunnels, apparaten en logs voor alle locaties.",
        "mode": "markdown"
      },
      "transparent": true
    },
    {
      "id": 2,
      "type": "row",
      "title": "1. Site Status Overzicht",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 2
      },
      "collapsed": false
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Bornem",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 0,
        "y": 3
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "probe_success{site=\"Bornem\"}",
          "legendFormat": "ICMP",
          "refId": "A"
        },
        {
          "expr": "peplink_tunnel_up{device_name=\"Bornem\"}",
          "legendFormat": "PepVPN",
          "refId": "B"
        },
        {
          "expr": "peplink_device_online{device_name=\"Bornem\"}",
          "legendFormat": "IC2",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          }
        }
      },
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "orientation": "vertical"
      }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Venue",
      "gridPos": {
        "h": 5,
        "w": 4,
