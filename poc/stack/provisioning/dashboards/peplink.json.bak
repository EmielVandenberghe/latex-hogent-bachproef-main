    {
      "id": 16,
      "type": "timeseries",
      "title": "RTT Latency over tijd",
      "description": "Round-trip time via ICMP naar elke site. Hoge latency kan impact hebben op SRT/NDI streamingkwaliteit.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "probe_icmp_duration_seconds{phase=\"rtt\", job=\"blackbox_icmp\"} * 1000",
          "legendFormat": "{{site}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 50
              },
              {
                "color": "red",
                "value": 150
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "last"
          ]
        }
      }
    },
    {
      "id": 17,
      "type": "timeseries",
      "title": "Packet Loss %",
      "description": "Percentage mislukte ICMP probes over 5 minuten. Boven 5% = risico op stotteringen in livestream.",
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "(1 - avg_over_time(probe_success{job=\"blackbox_icmp\"}[5m])) * 100",
          "legendFormat": "{{site}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 1
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 20,
            "lineWidth": 2,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "last"
          ]
        }
      }
    },
    {
      "id": 18,
      "type": "timeseries",
      "title": "Jitter per site (ping mdev)",
      "description": "Jitter via 'ping -c 10 -i 0.2': mdev = mean deviation. Hoge jitter veroorzaakt onregelmatige SRT-buffers en NDI framerate-problemen.",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 20
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "expr": "ping_jitter_ms{job=\"ping_jitter\"}",
          "legendFormat": "{{site}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ms",
          "thresholds": {
            "steps": [
              {
                "color": "green"
              },
              {
                "color": "yellow",
                "value": 5
              },
              {
                "color": "red",
                "value": 20
              }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 10,
            "lineWidth": 2,
            "showPoints": "never"
          }
        }
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": [
            "mean",
            "max",
            "last"
          ]
        }
      }
    },
