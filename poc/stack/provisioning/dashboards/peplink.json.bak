        },
        {
          "expr": "peplink_snmp_reachable{device_name=\"Balance20X\"}",
          "legendFormat": "SNMP",
          "refId": "B"
        },
        {
          "expr": "peplink_local_api_reachable{device_name=\"Balance20X\"}",
          "legendFormat": "API",
