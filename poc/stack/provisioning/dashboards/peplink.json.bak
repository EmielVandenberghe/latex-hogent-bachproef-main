    {
      "id": 7,
      "type": "stat",
      "title": "Balance 20X",
      "description": "Fysieke Peplink Balance 20X \u2014 enterprise SNMP + lokale API",
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 16,
        "y": 3
      },
      "datasource": {
